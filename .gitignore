# Binaries
/colophon

# Go
*.test
*.out

# colophon build/publish output & cache (root project or any fixture)
public/
.colophon/
dist/
dist-*/

# Local agent tooling (machine-specific runtime state). Only shared/ and the
# project config (config/aide.json) are committable; everything else is local.
.aide/*
!.aide/shared/
!.aide/config
.aide/config/*
!.aide/config/aide.json

# Local env files (secrets / machine paths) — generated by gen-dotenv.sh
.env

# Editors / OS / assistant tooling
.DS_Store
.claude/
