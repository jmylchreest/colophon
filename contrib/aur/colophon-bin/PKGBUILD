pkgname=colophon-bin
pkgver=0.0.4
pkgrel=1
pkgdesc="Themed Markdown static-site generator with pluggable publishers (prebuilt binary)"
arch=('x86_64' 'aarch64')
url="https://github.com/jmylchreest/colophon"
license=('Apache-2.0')
