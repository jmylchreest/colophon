conflicts=('colophon')

_url="https://github.com/jmylchreest/colophon"
source=("LICENSE-${pkgver}::https://raw.githubusercontent.com/jmylchreest/colophon/v${pkgver}/LICENSE")
source_x86_64=("colophon-${pkgver}-x86_64.tar.gz::${_url}/releases/download/v${pkgver}/colophon_${pkgver}_linux_amd64.tar.gz")
source_aarch64=("colophon-${pkgver}-aarch64.tar.gz::${_url}/releases/download/v${pkgver}/colophon_${pkgver}_linux_arm64.tar.gz")

sha256sums=('25066970ea0a1dc0f4a791b97ed2e5025450031637d0e9621c03d1bb3048929c')
sha256sums_x86_64=('ab0f26ee39b9ecd37366a0d6846ab8ed9bd71835078413575da1e59e5a7770b2')
